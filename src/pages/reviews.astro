---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  platformRatings,
  reviews,
} from "../content/reviews/reviews.ts";

const title = "Guest Reviews - Casa Patron Vacation Rental in Alto, NM";
const description =
  "Read verified guest reviews of Casa Patron, a luxury vacation rental in Alto, New Mexico. Rated 4.9/5 across 140+ reviews on Airbnb, VRBO, Evolve, and Booking.com.";

const keywords = [
  "casa patron reviews",
  "alto nm cabin reviews",
  "ruidoso vacation rental reviews",
  "casa patron alto",
  "ski apache lodging reviews",
  "new mexico cabin reviews",
];

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Reviews", url: "/reviews/" },
];

const totalReviews = platformRatings.reduce((sum, p) => sum + p.reviewCount, 0);
const weightedSum = platformRatings
  .filter((p) => p.maxRating === 5)
  .reduce((sum, p) => sum + p.rating * p.reviewCount, 0);
const weightedCount = platformRatings
  .filter((p) => p.maxRating === 5)
  .reduce((sum, p) => sum + p.reviewCount, 0);
const averageRating = Math.round((weightedSum / weightedCount) * 100) / 100;

const reviewsSchema = {
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  name: "Casa Patron",
  description:
    "Luxury vacation rental in Alto, New Mexico near Ruidoso and Ski Apache.",
  image: "https://casapatronalto.com/cp-mural.jpg",
  telephone: "+1-817-223-0272",
  address: {
    "@type": "PostalAddress",
    streetAddress: "176 Neill Rd",
    addressLocality: "Alto",
    addressRegion: "NM",
    postalCode: "88312",
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 33.41047791700064,
    longitude: -105.6845322600749,
  },
  url: "https://casapatronalto.com/",
  priceRange: "$240-$900 per night",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: averageRating,
    bestRating: 5,
    worstRating: 1,
    reviewCount: totalReviews,
  },
  review: reviews.map((review) => ({
    "@type": "Review",
    author: {
      "@type": "Person",
      name: review.author,
    },
    datePublished: review.isoDate,
    reviewRating: {
      "@type": "Rating",
      ratingValue: review.rating,
      bestRating: 5,
      worstRating: 1,
    },
    reviewBody: review.text,
  })),
};

function renderStars(rating: number): string {
  return "★".repeat(rating) + "☆".repeat(5 - rating);
}
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  schemaMarkup={reviewsSchema}
  type="website"
  breadcrumbs={breadcrumbs}
>
  <!-- Hero Section -->
  <div
    class="bg-gradient-to-br from-secondary to-tertiary text-white py-16 mb-12 rounded-xl"
  >
    <div class="text-center max-w-4xl mx-auto px-4">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">Guest Reviews</h1>
      <p class="text-xl md:text-2xl leading-relaxed opacity-90">
        Rated <strong>{averageRating}/5</strong> by <strong>{totalReviews}+</strong> guests
        across Airbnb, VRBO, Evolve, and Booking.com.
      </p>
    </div>
  </div>

  <!-- Platform Ratings -->
  <section class="mb-12" aria-label="Ratings by platform">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {
        platformRatings.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group rounded-2xl border border-secondary/15 bg-white p-5 text-center shadow-md transition-all hover:shadow-lg hover:scale-[1.02]"
          >
            <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">
              {platform.platform}
            </p>
            <p class="mt-2 text-3xl font-bold text-secondary">
              {platform.rating}<span class="text-lg text-gray-400">/{platform.maxRating}</span>
            </p>
            <p class="mt-1 text-primary text-lg" aria-label={`${platform.rating} out of ${platform.maxRating} stars`}>
              {platform.maxRating === 5
                ? "★★★★★"
                : "★★★★★"}
            </p>
            <p class="mt-1 text-sm text-gray-500">
              {platform.reviewCount} reviews
            </p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Reviews -->
  <section aria-label="Guest reviews">
    <h2 class="text-3xl font-bold text-grey-neutral mb-8">
      What Our Guests Say
    </h2>
    <div class="grid gap-6 md:grid-cols-2">
      {
        reviews.map((review) => (
          <article class="rounded-2xl border border-gray-100 bg-white p-6 shadow-md">
            <div class="flex items-start justify-between mb-3">
              <div>
                <p class="font-bold text-grey-neutral text-lg">
                  {review.author}
                </p>
                <time
                  datetime={review.isoDate}
                  class="text-sm text-gray-500"
                >
                  {review.date}
                </time>
              </div>
            </div>
            <p
              class="text-primary text-lg mb-3"
              aria-label={`${review.rating} out of 5 stars`}
            >
              {renderStars(review.rating)}
            </p>
            <blockquote class="text-gray-700 leading-relaxed">
              <p>&ldquo;{review.text}&rdquo;</p>
            </blockquote>
            {review.groupSize && (
              <p class="mt-3 text-xs font-medium text-gray-400 uppercase tracking-wide">
                {review.groupSize}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </section>

  <!-- CTA Section -->
  <section class="mt-16 mb-8 text-center">
    <div
      class="rounded-2xl bg-gradient-to-r from-secondary to-tertiary p-10 text-white"
    >
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Ready to Experience Casa Patron?
      </h2>
      <p class="text-lg mb-6 opacity-90 max-w-2xl mx-auto">
        Join over {totalReviews} happy guests who have made unforgettable
        memories at our mountain retreat in Alto, New Mexico.
      </p>
      <a
        href="/contact-us/"
        class="inline-block bg-primary text-grey-neutral font-semibold text-lg px-8 py-4 rounded-lg hover:bg-yellow-400 hover:scale-[1.02] transition-all duration-200 shadow-lg hover:shadow-xl focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-primary"
      >
        Book Your Stay
      </a>
    </div>
  </section>
</BaseLayout>
